{
  "name": "server-hub-v7",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix host-x\" \"npm run dev --prefix api-server\"",
    "build": "npm run build --prefix host-x",
    "start": "node --enable-source-maps api-server/dist/index.mjs",
    "db:push": "npm run db:push --prefix lib/db",
    "db:studio": "npm run db:studio --prefix lib/db"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}